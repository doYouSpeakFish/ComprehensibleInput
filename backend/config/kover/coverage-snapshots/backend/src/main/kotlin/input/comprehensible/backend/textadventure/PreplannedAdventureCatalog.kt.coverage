⚪   package input.comprehensible.backend.textadventure
⚪   
⚪   /**
⚪    * A hand-authored adventure that ships with the backend, ready to play without asking the model to
⚪    * invent one. A preplanned adventure carries everything a freshly generated adventure would have by
⚪    * the time its opening scene is stored: a fixed language pair and difficulty, a cover image, a title,
⚪    * the private [plan] that guides the narrator, and the [firstMessage] the player sees first.
⚪    *
⚪    * It is deliberately the same shape as a generated adventure so that, once a player starts it, it
⚪    * becomes an ordinary adventure: it is copied into a private, per-player adventure (keyed by the
⚪    * player's account) and continued through the normal message endpoints. Two players who start the
⚪    * same preplanned adventure therefore get two independent adventures and never see each other's
⚪    * messages.
⚪    *
⚪    * [id] is a stable catalogue identifier used to start the adventure; it is not the id of any player's
⚪    * adventure instance. [plan] is private narrator context and, like every plan, is never exposed
⚪    * through the API.
⚪    */
🟢   data class PreplannedAdventure(
🟢       val id: String,
🟢       val learningLanguage: String,
🟢       val translationLanguage: String,
🟢       val languageLevel: String,
🟢       val imageId: String,
🟢       val title: String,
🟢       val translatedTitle: String,
🟢       val plan: AdventurePlanStructuredResponse,
🟢       val firstMessage: PreplannedFirstMessage,
⚪   )
⚪   
⚪   /**
⚪    * The opening narrator message of a preplanned adventure. [paragraphs] hold the learning-language
⚪    * sentences and their matching translations (one [PersistedAdventureParagraph] per paragraph), just
⚪    * as a generated opening message would. [note] is an optional private narrator note stored on the
⚪    * opening message; like all notes it is never exposed through the API and is only fed back to the
⚪    * model as context on later turns.
⚪    */
⚪   data class PreplannedFirstMessage(
🟢       val paragraphs: List<PersistedAdventureParagraph>,
🟢       val note: String? = null,
⚪   )
⚪   
⚪   /**
⚪    * The fixed catalogue of preplanned adventures bundled with the backend.
⚪    *
⚪    * Each entry is written out in full, like code: the plan is a structured [AdventurePlanStructuredResponse]
⚪    * (the same type the model returns when it plans an adventure) so it stays complete and consistent, and
⚪    * the opening message is written sentence by sentence with a matching translation for every sentence.
⚪    * The [init] block enforces these invariants so a malformed adventure fails fast at start-up rather
⚪    * than at play time.
⚪    */
⚪   object PreplannedAdventureCatalog {
⚪   
🟢       val adventures: List<PreplannedAdventure> = listOf(
🟢           theDarkenedLighthouse(),
⚪       )
⚪   
🟢       private val adventuresById: Map<String, PreplannedAdventure> = adventures.associateBy { it.id }
⚪   
🟢       fun findById(id: String): PreplannedAdventure? = adventuresById[id]
⚪   
🟢       init {
🟡           require(adventures.isNotEmpty()) { "The preplanned adventure catalogue must not be empty" }
🟡           require(adventuresById.size == adventures.size) { "Preplanned adventure ids must be unique" }
🟢           adventures.forEach(::validate)
⚪       }
⚪   
⚪       private fun validate(adventure: PreplannedAdventure) {
🟡           require(adventure.id.isNotBlank()) { "A preplanned adventure must have a non-blank id" }
🟡           require(adventure.learningLanguage.isNotBlank()) { "${adventure.id}: learning language must not be blank" }
🟡           require(adventure.translationLanguage.isNotBlank()) { "${adventure.id}: translation language must not be blank" }
🟡           require(adventure.learningLanguage != adventure.translationLanguage) {
🔴               "${adventure.id}: learning and translation languages must differ"
⚪           }
🟡           require(adventure.languageLevel in SUPPORTED_LANGUAGE_LEVELS) {
🔴               "${adventure.id}: unsupported language level '${adventure.languageLevel}'"
⚪           }
🟡           require(AdventureImageCatalog.contains(adventure.imageId)) {
🔴               "${adventure.id}: image '${adventure.imageId}' is not in the cover image catalogue"
⚪           }
🟡           require(adventure.title.isNotBlank()) { "${adventure.id}: title must not be blank" }
🟡           require(adventure.translatedTitle.isNotBlank()) { "${adventure.id}: translated title must not be blank" }
🟢           validatePlan(adventure)
🟢           validateFirstMessage(adventure)
⚪       }
⚪   
⚪       private fun validatePlan(adventure: PreplannedAdventure) {
🟢           val plan = adventure.plan
🟡           require(plan.characterDescription.isNotBlank()) { "${adventure.id}: plan needs a character description" }
🟡           require(plan.inventory.isNotBlank()) { "${adventure.id}: plan needs a starting inventory" }
🟡           require(plan.hook.isNotBlank()) { "${adventure.id}: plan needs a hook" }
🟡           require(plan.truthBehindHook.isNotBlank()) { "${adventure.id}: plan needs the truth behind the hook" }
🟡           require(plan.coreChallenge.isNotBlank()) { "${adventure.id}: plan needs a core challenge" }
🟡           require(plan.locations.isNotEmpty()) { "${adventure.id}: plan needs at least one location" }
🟡           require(plan.npcs.isNotEmpty()) { "${adventure.id}: plan needs at least one NPC" }
⚪       }
⚪   
⚪       private fun validateFirstMessage(adventure: PreplannedAdventure) {
🟢           val paragraphs = adventure.firstMessage.paragraphs
🟡           require(paragraphs.isNotEmpty()) { "${adventure.id}: the first message must have at least one paragraph" }
🟢           paragraphs.forEach { paragraph ->
🟡               require(paragraph.sentences.isNotEmpty()) { "${adventure.id}: a first-message paragraph has no sentences" }
🟡               require(paragraph.sentences.size == paragraph.translatedSentences.size) {
🔴                   "${adventure.id}: every first-message sentence must have exactly one translation"
⚪               }
🟢           }
⚪       }
⚪   }
⚪   
⚪   /**
⚪    * "The Darkened Lighthouse" — a Spanish (B1) coastal mystery translated into English.
⚪    *
⚪    * The lighthouse has gone dark in a storm and a ship is drifting toward the rocks. The player, Lucía,
⚪    * must get inside, find the trapped keeper, recover the gear that turns the lamp and relight it in
⚪    * time. The twist is gentle rather than villainous: the keeper's nephew hid the gear out of love, to
⚪    * force his stubborn uncle off the lonely cliff, and the best ending is reached by understanding him.
⚪    */
🟢   private fun theDarkenedLighthouse(): PreplannedAdventure = PreplannedAdventure(
🟢       id = "darkened-lighthouse-es-b1",
🟢       learningLanguage = "es",
🟢       translationLanguage = "en",
🟢       languageLevel = "B1",
🟢       imageId = "lighthouse-cliff",
🟢       title = "El faro a oscuras",
🟢       translatedTitle = "The Darkened Lighthouse",
🟢       plan = darkenedLighthousePlan(),
🟢       firstMessage = darkenedLighthouseFirstMessage(),
⚪   )
⚪   
🟢   private fun darkenedLighthousePlan(): AdventurePlanStructuredResponse = AdventurePlanStructuredResponse(
🟢       characterDescription = "The player is Lucía, a young woman from the fishing village of Las Gaviotas at the foot " +
⚪           "of the cliff. As a child she spent long hours alone, and the old lighthouse keeper, Don Tomás, taught her " +
⚪           "to read using the ships' logbooks. She is brave, curious and fiercely loyal to the few people who were " +
⚪           "ever kind to her. Tonight she has come up to the lighthouse because Don Tomás sent for her.",
🟢       inventory = "Lucía carries Don Tomás's letter, which reads only 'Ven. Te necesito.' ('Come. I need you.'); a " +
⚪           "small brass oil lamp with almost no oil left, so its flame will soon die; a yellow raincoat against the " +
⚪           "storm; and a small folding knife.",
🟢       hook = "For the first time in living memory the great cliff-top lighthouse has gone completely dark, on the " +
⚪           "night of a violent storm. Out at sea a fishing boat, the Estrella del Norte, is steering slowly toward " +
⚪           "the rocks below and will be wrecked unless the lamp is relit. Don Tomás, who sent for Lucía, is nowhere " +
⚪           "to be seen, and the heavy red door of the lighthouse is locked.",
🟢       truthBehindHook = "The light did not fail by accident. Don Tomás's nephew, Julián, secretly removed the heavy " +
⚪           "brass gear that turns the lamp and hid it, hoping a failed lighthouse would force the authorities to close " +
⚪           "it and finally bring his stubborn, ageing uncle off the lonely cliff to live safely with him in the city. " +
⚪           "Julián never dreamed a ship would be caught in a storm the very same night. Don Tomás discovered what his " +
⚪           "nephew had done and, hurrying to the cellar for the spare gear, fell on the stairs and hurt his leg; he is " +
⚪           "now trapped below, unable to climb. Julián is hiding at the top of the tower, ashamed and frightened.",
🟢       coreChallenge = "Lucía must relight the lighthouse lamp before the Estrella del Norte reaches the rocks. To do " +
⚪           "that she must get inside the locked tower, find Don Tomás and learn that the lamp will not turn because its " +
⚪           "brass gear is missing, recover the hidden gear, fit it back into the mechanism, fill the lamp with oil and " +
⚪           "light it. The heart of the challenge is Julián: he is not a villain but a frightened young man who acted " +
⚪           "out of love. Lucía can take the gear back by force or threat, but the best resolution is to talk with him, " +
⚪           "understand why he did it, and persuade him to give it back and help. The pressure comes from the " +
⚪           "approaching ship and from Lucía's own oil lamp slowly running dry, which threatens to leave her in the dark.",
🟢       locations = darkenedLighthouseLocations(),
🟢       npcs = darkenedLighthouseNpcs(),
⚪   )
⚪   
🟢   private fun darkenedLighthouseLocations(): List<AdventurePlanLocationResponse> = listOf(
🟢       AdventurePlanLocationResponse(
🟢           name = "El camino del acantilado y la puerta roja (the cliff path and the red door)",
🟢           description = "A steep path climbs from the village to the lighthouse through wind and rain. At the top " +
⚪               "stands the round white tower with a heavy red iron door, now locked. To the right of the door are " +
⚪               "three worn stone steps; the third step is cracked, and under it, beneath a loose stone, Don Tomás " +
⚪               "always keeps a spare iron key to the door. Far above, a rusty old foghorn and some seabird nests " +
⚪               "cling to the outside gallery.",
⚪       ),
🟢       AdventurePlanLocationResponse(
🟢           name = "La planta baja (the ground floor)",
🟢           description = "Inside the door is a cold, round stone room. There is a wooden desk holding the open " +
⚪               "ship's logbook and a tin of long matches, a row of hooks with oilskin coats, and an unlit storm " +
⚪               "lantern. A spiral iron staircase winds upward toward the bedroom and the lamp room. Set into the " +
⚪               "floor is a wooden trapdoor with an iron ring that leads down to the cellar, and from below a faint " +
⚪               "voice can be heard calling for help.",
⚪       ),
🟢       AdventurePlanLocationResponse(
🟢           name = "El sótano (the cellar)",
🟢           description = "A low, damp store-room reached by a short wooden staircase. Barrels of lamp oil line one " +
⚪               "wall and a funnel hangs from a nail. Don Tomás is here, propped against the barrels with an injured " +
⚪               "leg, unable to climb. He can explain everything: the lamp itself is sound but will not turn because " +
⚪               "the brass gear is gone, and his nephew Julián is the only other person on the cliff tonight. He " +
⚪               "begs Lucía to relight the lamp and to be gentle with the boy. He can give her the tin of matches.",
⚪       ),
🟢       AdventurePlanLocationResponse(
🟢           name = "El dormitorio del farero (the keeper's bedroom)",
🟢           description = "A small round room off the first landing, with a narrow bed, a stove and a wooden chest. " +
⚪               "Inside the chest is Don Tomás's diary, whose last pages describe Julián's letters begging him to " +
⚪               "leave the lighthouse, and his own refusals. A small key hangs on a hook by the window; it opens the " +
⚪               "tool cabinet up in the lamp room. The window looks out onto the gallery where the foghorn stands.",
⚪       ),
🟢       AdventurePlanLocationResponse(
🟢           name = "La sala de la lámpara (the lamp room)",
🟢           description = "The glass-walled top of the tower holds the great lamp and its lens. At its base is the " +
⚪               "turning mechanism, with an empty square socket where the heavy brass gear belongs; without the gear " +
⚪               "the lamp can neither rotate nor be lit safely. An oil reservoir must be filled from the cellar's " +
⚪               "oil, and a locked tool cabinet (opened by the bedroom key) holds cleaning cloths and the crank " +
⚪               "handle. A low door leads out onto the windy gallery.",
⚪       ),
🟢       AdventurePlanLocationResponse(
🟢           name = "La galería y la vieja sirena de niebla (the gallery and the old foghorn)",
🟢           description = "A narrow walkway runs around the outside of the lamp room, high above the crashing sea. " +
⚪               "The rusted foghorn stands here, its wide brass mouth deep enough to hide something inside. Wrapped " +
⚪               "in oilcloth deep within the foghorn is the missing brass gear. Julián is out here in the rain, " +
⚪               "gripping the railing, watching the ship's lights draw closer. If Lucía is kind he confesses the " +
⚪               "truth and shows her the gear; if she threatens him he panics.",
⚪       ),
⚪   )
⚪   
🟢   private fun darkenedLighthouseNpcs(): List<AdventurePlanNpcResponse> = listOf(
🟢       AdventurePlanNpcResponse(
🟢           name = "Don Tomás",
🟢           description = "The lighthouse keeper, in his seventies, who taught Lucía to read. Honest, proud and " +
⚪               "stubborn, he has kept this light for forty years and refuses to leave it. Tonight he is trapped in " +
⚪               "the cellar with an injured leg after falling on the stairs. He wants two things: the lamp relit to " +
⚪               "save the ship, and his nephew forgiven rather than punished. He can give Lucía the matches, tell " +
⚪               "her the gear is missing and that Julián is somewhere above, and explain how the lamp works, but he " +
