🟢               .mapNotNull { row -> row[AdventureMessagesTable.note]?.takeIf { it.isNotBlank() } }
🟢           AdventureNarrationContext(
🟢               plan = adventureRow[AdventuresTable.plan],
🟢               notes = notes,
⚪           )
⚪       }
