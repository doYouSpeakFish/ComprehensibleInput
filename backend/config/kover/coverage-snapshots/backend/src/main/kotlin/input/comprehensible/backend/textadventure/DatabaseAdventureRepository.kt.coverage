🟢           onDelete = ReferenceOption.CASCADE,
⚪       )
🟢       val paragraphIndex = integer("paragraph_index")
🟢       val sentenceIndex = integer("sentence_index")
🟢       val language = varchar("language", length = 64)
🟢       val text = text("text")
⚪   
🟢       override val primaryKey: PrimaryKey = PrimaryKey(
🟢           messageId,
🟢           paragraphIndex,
🟢           sentenceIndex,
🟢           language,
⚪       )
⚪   }
